# Required for OpenAI. Optional for local providers.
OPENAI_API_KEY=your_key_here

# Optional: override to use other OpenAI-compatible providers (e.g. Ollama)
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: model name for your provider
OPENAI_MODEL=gpt-4o-mini

# Optional: use your medical_pipeline FastAPI backend instead of direct OpenAI
# If set, /api/chat will proxy to this backend.
MEDICAL_API_BASE_URL=http://localhost:8000
